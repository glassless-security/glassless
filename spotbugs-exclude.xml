<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
   <!-- False positive: SecureRandom is assigned to parameter and reused for both
        nextBytes() and super.engineInit(), but SpotBugs can't track parameter reassignment -->
   <Match>
      <Class name="net.glassless.provider.internal.cipher.AbstractPBECipher"/>
      <Method name="engineInit"/>
      <Bug pattern="DMI_RANDOM_USED_ONLY_ONCE"/>
   </Match>
</FindBugsFilter>
